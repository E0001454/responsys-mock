ARG VITE_MS_COLUMNAS_CAMPANA_USE_MOCK

ARG VITE_MS_BITACORA_REAL
ARG VITE_MS_BITACORA_MOCK
ARG VITE_MS_BITACORA_USE_MOCK

ARG VITE_MS_HORARIOS_LINEA_REAL
ARG VITE_MS_HORARIOS_LINEA_MOCK
ARG VITE_MS_HORARIOS_LINEA_USE_MOCK
ARG VITE_MS_HORARIOS_CAMPANA_REAL
ARG VITE_MS_HORARIOS_CAMPANA_MOCK
ARG VITE_MS_HORARIOS_CAMPANA_USE_MOCK

ARG VITE_MS_MONITOR_LINEA_REAL
ARG VITE_MS_MONITOR_LINEA_MOCK
ARG VITE_MS_MONITOR_LINEA_USE_MOCK
ARG VITE_MS_MONITOR_CAMPANA_REAL
ARG VITE_MS_MONITOR_CAMPANA_MOCK
