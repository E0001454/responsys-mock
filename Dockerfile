ARG VITE_MS_TAREAS_CAMPANA_REAL
ARG VITE_MS_TAREAS_CAMPANA_MOCK
ARG VITE_MS_TAREAS_CAMPANA_USE_MOCK

ARG VITE_MS_COLUMNAS_LINEA_REAL
